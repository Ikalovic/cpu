    %load/vec4 v0x573d117e2a80_0;
    %addi 1, 0, 32;
    %store/vec4 v0x573d117e2a80_0, 0, 32;
T_11.8 ;
    %vpi_call 2 59 "$display", "[RESULT] original_sid=%h", &A<v0x573d117d7aa0, 96> {0 0 0};
    %vpi_call 2 60 "$display", "[RESULT] sorted_sid=%h", &A<v0x573d117d7aa0, 97> {0 0 0};
    %load/vec4 v0x573d117e2a80_0;
    %cmpi/e 0, 0, 32;
    %jmp/0xz  T_11.10, 4;
    %vpi_call 2 63 "$display", "[PASS] lab-6 sid sorting simulation passed." {0 0 0};
    %jmp T_11.11;
T_11.10 ;
    %vpi_call 2 65 "$display", "[FAIL] lab-6 sid sorting simulation failed with %0d error(s).", v0x573d117e2a80_0 {0 0 0};
T_11.11 ;
    %delay 20, 0;
    %vpi_call 2 68 "$finish" {0 0 0};
    %end;
    .thread T_11;
