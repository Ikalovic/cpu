@@ -0,0 +1,19 @@
+`ifndef PIPE_DEFS_V
+`define PIPE_DEFS_V
+
+`define PIPE_WB_ALU 2'b00
+`define PIPE_WB_MEM 2'b01
+
+`define PIPE_ALU_ADD  5'd0
+`define PIPE_ALU_SUB  5'd1
+`define PIPE_ALU_SLT  5'd2
+`define PIPE_ALU_SLTU 5'd3
+`define PIPE_ALU_XOR  5'd4
+`define PIPE_ALU_OR   5'd5
+`define PIPE_ALU_AND  5'd6
+`define PIPE_ALU_SLL  5'd7
+`define PIPE_ALU_SRL  5'd8
+`define PIPE_ALU_SRA  5'd9
+`define PIPE_ALU_LUI  5'd10
+
+`endif

--- a/pipeline/pipecomp.v
+++ b/pipeline/pipecomp.v
@@ -0,0 +1,36 @@
+module pipecomp(clk, rstn, reg_sel, reg_data);
+    input          clk, rstn;
+    input  [4:0]   reg_sel;
+    output [31:0]  reg_data;
+
+    wire [31:0] instr;
+    wire [31:0] PC;
+    wire        MemWrite;
+    wire [31:0] dm_addr, dm_din, dm_dout;
+
+    PipelineCPU U_PIPECPU(
+        .clk(clk),
+        .reset(rstn),
+        .inst_in(instr),
+        .Data_in(dm_dout),
+        .mem_w(MemWrite),
+        .PC_out(PC),
+        .Addr_out(dm_addr),
+        .Data_out(dm_din),
+        .reg_sel(reg_sel),
+        .reg_data(reg_data)
+    );
+
+    dm U_DM(
+        .clk(clk),
+        .DMWr(MemWrite),
+        .addr(dm_addr),
+        .din(dm_din),
+        .dout(dm_dout)
+    );
+
+    im U_imem(
+        .addr(PC[31:2]),
+        .dout(instr)
+    );
+endmodule

--- a/pipeline/pipecomp_tb.v
+++ b/pipeline/pipecomp_tb.v
@@ -0,0 +1,70 @@
+`timescale 1ns/1ns
+
+module pipecomp_tb();
+  reg clk;
+  reg rstn;
+  reg [4:0] reg_sel;
+  wire [31:0] reg_data;
+
+  integer errors;
+  integer i;
+
+  pipecomp dut(.clk(clk), .rstn(rstn), .reg_sel(reg_sel), .reg_data(reg_data));
+
+  initial begin
+    $readmemh("rv32_sid_sort_sim.dat", dut.U_imem.RAM, 0, 54);
+    for (i = 0; i < 128; i = i + 1) begin
+      dut.U_DM.dmem[i] = 32'h0000_0000;
+    end
+
+    clk = 1'b1;
+    rstn = 1'b1;
+    reg_sel = 5'd0;
+    errors = 0;
+    #10;
+    rstn = 1'b0;
+  end
+
+  always begin
+    #5 clk = ~clk;
+  end
+
+  initial begin
+    $dumpfile("pipe_cpu_sid_sort.vcd");
+    $dumpvars(0, pipecomp_tb);
+
+    #8000;
+
+    if (dut.U_DM.dmem[96] !== 32'h5487_3530) begin
+      $display("[FAIL] mem[0x180] expected original sid 0x54873530, got %h", dut.U_DM.dmem[96]);
+      errors = errors + 1;
+    end
+    if (dut.U_DM.dmem[97] !== 32'h0334_5578) begin
+      $display("[FAIL] mem[0x184] expected sorted sid 0x03345578, got %h", dut.U_DM.dmem[97]);
+      errors = errors + 1;
+    end
+    if (dut.U_PIPECPU.U_RF.rf[1] !== 32'hffff_0004) begin
+      $display("[FAIL] x1 expected 0xffff0004, got %h", dut.U_PIPECPU.U_RF.rf[1]);
+      errors = errors + 1;
+    end
+    if (dut.U_PIPECPU.U_RF.rf[2] !== 32'hffff_000c) begin
+      $display("[FAIL] x2 expected 0xffff000c, got %h", dut.U_PIPECPU.U_RF.rf[2]);
+      errors = errors + 1;
+    end
+    if (dut.U_PIPECPU.U_RF.rf[5] !== 32'h0000_0100) begin
+      $display("[FAIL] x5 expected 0x00000100, got %h", dut.U_PIPECPU.U_RF.rf[5]);
+      errors = errors + 1;
+    end
+
+    $display("[RESULT] original_sid=%h", dut.U_DM.dmem[96]);
+    $display("[RESULT] sorted_sid=%h", dut.U_DM.dmem[97]);
+
+    if (errors == 0)
+      $display("[PASS] lab-6 pipeline sid sorting simulation passed.");
+    else
+      $display("[FAIL] lab-6 pipeline sid sorting simulation failed with %0d error(s).", errors);
+
+    #20;
+    $finish;
+  end
+endmodule

--- a/pipeline/pl_final_wave_tb.v
+++ b/pipeline/pl_final_wave_tb.v
@@ -0,0 +1,59 @@
+`timescale 1ns/1ns
+
+module pl_final_wave_tb();
+  reg clk;
+  reg rstn;
+
+  integer i;
+  integer cycles;
+  reg [1023:0] imem_file;
+  reg [1023:0] vcd_file;
+
+  plcomp dut(.clk(clk), .rstn(rstn));
+
+  initial begin
+    if (!$value$plusargs("VCD=%s", vcd_file)) begin
+      vcd_file = "pl_final_wave.vcd";
+    end
+    $dumpfile(vcd_file);
+    $dumpvars(0, pl_final_wave_tb);
+
+    if (!$value$plusargs("IMEM=%s", imem_file)) begin
+      $display("[ERROR] missing +IMEM=<path>");
+      $finish;
+    end
+    if (!$value$plusargs("CYCLES=%d", cycles)) begin
+      cycles = 200;
+    end
+
+    $readmemh(imem_file, dut.U_imem.RAM);
+    for (i = 0; i < 128; i = i + 1) begin
+      dut.U_DM.dmem[i] = 32'h0000_0000;
+    end
+
+    clk = 1'b0;
+    rstn = 1'b1;
+    #50;
+    rstn = 1'b0;
+
+    repeat (cycles) @(posedge clk);
+
+    $display("[SNAPSHOT] registers");
+    $display("[REG] x0=00000000");
+    for (i = 1; i < 32; i = i + 1) begin
+      $display("[REG] x%0d=%08x", i, dut.U_PLCPU.U_RF.rf[i]);
+    end
+
+    $display("[SNAPSHOT] memory");
+    for (i = 0; i < 64; i = i + 1) begin
+      $display("[MEM] m%0d=%08x", i, dut.U_DM.dmem[i]);
+    end
+
+    $display("[VCD] %0s", vcd_file);
+    $finish;
+  end
+
+  always begin
+    #5 clk = ~clk;
+  end
+endmodule

